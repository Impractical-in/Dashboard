{
  "name": "local-dashboard",
  "version": "1.0.4",
  "private": true,
  "description": "Terminal-style local dashboard with optional server sync and backup workflows.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/server.js",
    "lint": "eslint . --ext .js,.cjs,.mjs --max-warnings=0",
    "format": "prettier --write \"README.md\" \"package.json\" \"eslint.config.js\" \"tools/**/*.mjs\" \"tests/**/*.js\" \"server/lib/**/*.js\" \".github/**/*.md\" \".github/**/*.yml\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"README.md\" \"package.json\" \"eslint.config.js\" \"tools/**/*.mjs\" \"tests/**/*.js\" \"server/lib/**/*.js\" \".github/**/*.md\" \".github/**/*.yml\" \"docs/**/*.md\"",
    "test": "node --test tests/**/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test tests/**/*.test.js",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:e2e:install": "playwright install chromium",
    "version:sync": "node tools/sync-version.mjs",
    "version:check": "node tools/sync-version.mjs --check",
    "version:bump:patch": "node tools/bump-version.mjs patch",
    "version:bump:minor": "node tools/bump-version.mjs minor",
    "version:bump:major": "node tools/bump-version.mjs major",
    "verify": "npm run version:check && npm run lint && npm run test && npm run test:e2e && npm run format:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "c8": "^10.1.3",
    "eslint": "^9.22.0",
    "prettier": "^3.5.2"
  }
}
