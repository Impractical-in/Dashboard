# Local backup exports
/dashboard-backup.json
**/dashboard-backup.json

# User data folder (keep README)
/user_data/*
!/user_data/README.md

# Runtime pid files
script_test/.dashboard-server.pid
script_test/.dashboard-ollama.pid

# Extra safety: do not commit local runtime stats/state exports
/dashboard.json
**/dashboard.json
/dashboard*.json
**/dashboard*.json
/server_stats*.json
**/server_stats*.json
/dserver_stats*.json
**/dserver_stats*.json

# Misc local artifacts
**/.DS_Store
*.log

# Tooling artifacts
/node_modules/
/coverage/
/.nyc_output/
/playwright-report/
/test-results/
/testing/
